// PLACEHOLDERS: __PROJECT_BASE_URL__ __API_LOGIN_PATH__ __API_TOKEN_FIELD__
// Generated by webtest-orch.
//
// AUTH STRATEGY (in priority order):
//   1. SUPABASE_URL + SUPABASE_ANON_KEY env → Supabase Auth (most common SaaS BaaS)
//   2. TEST_API_LOGIN_PATH env (custom JWT API)
//   3. UI login fallback (anchored regex, polls localStorage for SPA stay-on-path apps)
//
// POST-AUTH STATE SEEDING — see seedOnboardingFlags() below.
// Apps with feature-discovery tours / hint overlays must seed flags into
// localStorage BEFORE saving storageState; otherwise downstream specs fail at
// the first interaction (overlays intercept all clicks).

import { test as setup, expect } from '@playwright/test';
import * as fs from 'fs';
import * as path from 'path';

const authFile = 'playwright/.auth/user.json';

// Default key patterns whose values get auto-flipped to "true" before storageState.
// Override per-project via TEST_ONBOARDING_FLAGS env (JSON array of exact key names).
const DEFAULT_ONBOARDING_PATTERNS = [
  /^.+-features-discovered$/i,
  /^.+-onboarding-complete$/i,
  /^.+-tour-seen$/i,
  /^.+-hints-seen$/i,
  /^.+-welcome-dismissed$/i,
];

async function seedOnboardingFlags(page: import('@playwright/test').Page) {
  const customJson = process.env.TEST_ONBOARDING_FLAGS;
  const customFlags: string[] = customJson ? JSON.parse(customJson) : [];
  const patternSources = DEFAULT_ONBOARDING_PATTERNS.map((r) => r.source);

  await page.evaluate(({ customFlags, patternSources }) => {
    for (const k of customFlags) {
      try { localStorage.setItem(k, 'true'); } catch { /* quota / disabled */ }
    }
    const re = patternSources.map((p) => new RegExp(p, 'i'));
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i);
      if (key && re.some((r) => r.test(key))) {
        try { localStorage.setItem(key, 'true'); } catch { /* quota */ }
      }
    }
  }, { customFlags, patternSources });
}

setup('authenticate', async ({ request, page, baseURL: configBaseURL }) => {
  const email = process.env.TEST_USER_EMAIL;
  const password = process.env.TEST_USER_PASSWORD;
  const baseURL = configBaseURL || process.env.TEST_BASE_URL || '__PROJECT_BASE_URL__';

  if (!email || !password) {
    throw new Error('TEST_USER_EMAIL and TEST_USER_PASSWORD must be set in .env.test');
  }

  fs.mkdirSync(path.dirname(authFile), { recursive: true });

  // ── Method 1: Supabase Auth ─────────────────────────────────────
  const supabaseUrl = process.env.SUPABASE_URL;
  const supabaseAnonKey = process.env.SUPABASE_ANON_KEY;

  if (supabaseUrl && supabaseAnonKey) {
    console.log('[auth.setup] Supabase Auth detected');
    const projectRef = new URL(supabaseUrl).hostname.split('.')[0];
    const authResp = await request.post(
      `${supabaseUrl}/auth/v1/token?grant_type=password`,
      {
        data: { email, password },
        headers: { apikey: supabaseAnonKey, 'Content-Type': 'application/json' },
        timeout: 30_000,
      },
    );
    if (!authResp.ok()) {
      throw new Error(`Supabase auth failed HTTP ${authResp.status()}: ${await authResp.text()}`);
    }
    const sbSession = await authResp.json();
    const sbStorageKey = `sb-${projectRef}-auth-token`;

    await page.goto(baseURL);
    await page.evaluate(
      ({ key, value }) => localStorage.setItem(key, JSON.stringify(value)),
      { key: sbStorageKey, value: sbSession },
    );

    // Poll until token is settled (Supabase apps may rewrite on hydration)
    await expect.poll(
      () => page.evaluate((k) => Boolean(localStorage.getItem(k)), sbStorageKey),
      { timeout: 45_000, message: 'Supabase auth token did not appear in localStorage' },
    ).toBe(true);

    await seedOnboardingFlags(page);
    await page.context().storageState({ path: authFile });
    return;
  }

  // ── Method 2: Generic API login (custom JWT) ─────────────────────
  const apiLoginPath = process.env.TEST_API_LOGIN_PATH || '__API_LOGIN_PATH__';
  const tokenField = process.env.TEST_API_TOKEN_FIELD || '__API_TOKEN_FIELD__';
  let token: string | null = null;
  try {
    const response = await request.post(`${baseURL}${apiLoginPath}`, {
      data: { email, password },
      timeout: 10_000,
    });
    if (response.ok()) {
      const body = await response.json();
      token = body[tokenField] || body.token || body.jwt || null;
      console.log('[auth.setup] API login OK');
    } else {
      console.log(`[auth.setup] API login HTTP ${response.status()}, falling back to UI`);
    }
  } catch (e) {
    console.log(`[auth.setup] API login threw: ${e}. Falling back to UI`);
  }

  if (token) {
    await page.goto(baseURL);
    await page.evaluate((tk) => {
      localStorage.setItem('access_token', tk);
      localStorage.setItem('token', tk);
    }, token);
    await seedOnboardingFlags(page);
    await page.context().storageState({ path: authFile });
    return;
  }

  // ── Method 3: UI login fallback ─────────────────────────────────
  await page.goto(baseURL);

  const emailField = page.getByLabel(/email|e-?mail/i)
    .or(page.getByRole('textbox', { name: /email|e-?mail/i }))
    .or(page.getByPlaceholder(/email|e-?mail/i))
    .first();

  const passwordField = page.getByLabel(/password|пароль/i)
    .or(page.getByPlaceholder(/password|пароль/i))
    .first();

  // Anchored: avoid matching "Sign up" / "Sign in with Google"
  const submitButton = page.getByRole('button', {
    name: /^(sign in|log in|войти|вход)$/i,
  }).first();

  await emailField.fill(email);
  await passwordField.fill(password);
  await submitButton.click();

  // Wait for ANY of: URL change, logout button visible, or auth-token in localStorage.
  // SPAs (Supabase, NextAuth, Clerk) sometimes stay on the same path post-login.
  await Promise.race([
    page.waitForURL((url) => !/\/(login|signin|auth)\b/.test(url.toString()), { timeout: 30_000 }),
    expect(page.getByRole('button', { name: /^(log ?out|sign ?out|выйти)$/i }))
      .toBeVisible({ timeout: 30_000 }),
    expect.poll(
      () => page.evaluate(() =>
        Object.keys(localStorage).some((k) =>
          /^(access_token|token|jwt|auth_token|sb-.*-auth-token)$/i.test(k))),
      { timeout: 30_000 },
    ).toBe(true),
  ]);

  await seedOnboardingFlags(page);
  await page.context().storageState({ path: authFile });
});
